## Ignore Visual Studio temporary files, build results, and other files generated by popular editors

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options
.vs/
.vscode/

# MSTest test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Build results of an ATL Project
[Dd]ebugPS/
[Rr]eleasePS/
dlldata.c

# Benchmarking
BenchmarkDotNet.Artifacts/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/
*.nupkg
*.snupkg

# Tarballs
*.tar.gz

# Package directories
packages/
!**/packages/repositories.config
*.nupkg
*.snupkg

# NuGet packages
# The packages folder can be checked into source control,
# http://docs.nuget.org/consume/package-restore-workflow
**/[Pp]ackages/

# NuGet v3 and above
*.lock.json

# Coverage reports
coverage*/
*.cobertura.xml
*.opencover.xml
TestResults/

# Dotnet coverage tool
*.coveragexml

# Publish output
publish/

# Windows image file caches
Thumbs.db
ehthumbs.db

# macOS
.DS_Store
.AppleDouble
.LSOverride
__MACOSX

# Linux
*~

# JetBrains Rider
.idea/
*.sln.iml

# Roslyn
*.roslynanalyzer

# Logs
*.log
Logs/
